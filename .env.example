# Local-dev secrets. Copy to `.env` (gitignored) and fill in.
#
# NOTE: every var here is exposed to the renderer process because Vite's
# `envPrefix` in vite.config.ts whitelists the REPLICATE_ / ELEVENLABS_ /
# OPENAI_ / ANTHROPIC_ prefixes. Acceptable for a personal dev tool;
# unacceptable for installer builds shipped to contractors. Production
# routes these calls through `gaiare-next-server` so the tokens stay
# server-side.

# Replicate (mandatory for clip generation)
REPLICATE_API_TOKEN=

# Fireworks (chat assistant — Kimi K2.5 / Qwen / DeepSeek). Cheaper than
# Claude/GPT for the kind of long-context iterative prompt refinement
# the AI assistant does. Get a key at https://fireworks.ai/account/api-keys.
FIREWORKS_API_KEY=

# ElevenLabs (mandatory once narration step lands)
ELEVENLABS_API_KEY=

# Optional — only needed if the prompt-author step ever runs client-side.
# Production should call these via next-server / Mastra instead.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
