# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Env / secrets
.env
.env.*
!.env.example

# Tauri updater signing keys — the private key is delivered to the
# maintainer to store as a GitHub Actions secret, never committed. The
# public key lives (committed) inside src-tauri/tauri.conf.json instead.
gaiare-updater.key
gaiare-updater.key.pub

# Generated artefacts (kept local, S3 is source of truth)
/work/
/scratch/

# Sidecar binaries — downloaded per-platform via
# `scripts/download-ffmpeg.mjs` on `pnpm install`. Don't commit them
# (~30 MB each, platform-specific) — the postinstall hook regenerates
# what each host needs.
/src-tauri/binaries/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
